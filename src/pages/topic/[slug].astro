---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileHero from '../../components/ProfileHero.astro';
import TopicNav from '../../components/TopicNav.astro';
import PostCard from '../../components/PostCard.astro';
import { site, topicName } from '../../site';

export async function getStaticPaths() {
  const topics = (await getCollection('topics')).map((topic) => ({ slug: topic.id, ...topic.data }));
  return topics.map((topic) => ({ params: { slug: topic.slug } }));
}

const { slug } = Astro.params;
const topics = (await getCollection('topics'))
  .map((topic) => ({ slug: topic.id, ...topic.data }))
  .sort((a, b) => a.order - b.order);
const posts = (await getCollection('posts', ({ data }) => data.topic.includes(slug ?? ''))).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const title = topicName(topics, slug ?? '');
---

<BaseLayout title={title} description={`${site.name}的${title}专题文章。`}>
  <div class="page-shell">
    <ProfileHero />
    <TopicNav active={slug} />
    <section class="feed-heading">
      <div><p class="eyebrow">COLLECTION</p><h2>{title}</h2></div>
      <p>共 {posts.length} 篇文章</p>
    </section>
    <section class="post-grid">
      {posts.map((post) => <PostCard post={post} topics={topics} />)}
    </section>
  </div>
</BaseLayout>
