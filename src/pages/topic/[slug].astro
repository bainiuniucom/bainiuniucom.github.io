---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileHero from '../../components/ProfileHero.astro';
import TopicNav from '../../components/TopicNav.astro';
import PostCard from '../../components/PostCard.astro';
import { topics, topicName } from '../../site';

export function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug } }));
}

const { slug } = Astro.params;
const posts = (await getCollection('posts', ({ data }) => data.topic === slug)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const title = topicName(slug ?? '');
---

<BaseLayout title={title} description={`百万头牛的${title}专题文章。`}>
  <div class="page-shell">
    <ProfileHero />
    <TopicNav active={slug} />
    <section class="feed-heading">
      <div><p class="eyebrow">COLLECTION</p><h2>{title}</h2></div>
      <p>共 {posts.length} 篇文章</p>
    </section>
    <section class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </section>
  </div>
</BaseLayout>
