---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicName } from '../../site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, description, date, topic, cover, readTime } = post.data;
const formattedDate = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<BaseLayout title={title} description={description} image={cover}>
  <article class="article-shell">
    <header class="article-header">
      <a class="article-topic" href={`/topic/${topic}/`}>{topicName(topic)}</a>
      <h1>{title}</h1>
      <p class="article-deck">{description}</p>
      <div class="article-byline">
        <span class="byline-mark">牛</span>
        <span>百万头牛</span>
        <span>{formattedDate}</span>
        <span>预计阅读 {readTime} 分钟</span>
      </div>
    </header>
    {cover && <figure class="article-cover"><img src={cover} alt="" /></figure>}
    <div class="article-layout">
      {headings.length > 1 && (
        <aside class="article-toc">
          <strong>本文目录</strong>
          {headings.filter((heading) => heading.depth <= 3).map((heading) => (
            <a href={`#${heading.slug}`}>{heading.text}</a>
          ))}
        </aside>
      )}
      <div class="article-content"><Content /></div>
    </div>
    <footer class="article-end">
      <span>完</span>
      <p>以上仅为个人研究记录，不构成投资建议。投资有风险，决策需独立。</p>
      <a href="/">返回全部文章</a>
    </footer>
  </article>
</BaseLayout>
