---
import { site } from '../site';
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.name,
  description = site.description,
  image = '/images/investing-desk.png',
} = Astro.props;
const pageTitle = title === site.name ? title : `${title}｜${site.name}`;
const searchPosts = (await getCollection('posts')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff9f7" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="mini-brand" href="/" aria-label="返回首页">
        <img src="/images/logo-bainiuniu.webp" alt={site.name} />
      </a>
      <nav class="top-actions" aria-label="辅助导航">
        <a href="/about/">关于</a>
        <button class="search-trigger" type="button" aria-label="搜索文章" data-search-open>
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m16 16 5 5"></path></svg>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <a class="footer-brand" href="/" aria-label="返回首页"><img src="/images/logo-bainiuniu.webp" alt="" /><strong>{site.name}</strong></a>
      <p>© {new Date().getFullYear()} bainiuniu.com</p>
    </footer>
    <dialog class="search-dialog" data-search-dialog>
      <form method="dialog" class="search-head">
        <label for="site-search">搜索文章</label>
        <button aria-label="关闭搜索">关闭</button>
      </form>
      <input id="site-search" type="search" placeholder="输入公司、行业或文章标题…" autocomplete="off" data-search-input />
      <p class="search-hint" data-search-hint>输入关键词，搜索全部文章。</p>
      <ul class="search-results" aria-live="polite" data-search-results>
        {searchPosts.map((post) => (
          <li data-search-item data-search-text={`${post.data.title} ${post.data.description}`} hidden>
            <a href={`/articles/${post.id}/`}>
              <strong>{post.data.title}</strong>
              <span>{post.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </dialog>
    <script>
      const dialog = document.querySelector('[data-search-dialog]');
      const input = document.querySelector('[data-search-input]');
      const hint = document.querySelector('[data-search-hint]');
      const items = [...document.querySelectorAll('[data-search-item]')];
      document.querySelector('[data-search-open]')?.addEventListener('click', () => {
        if (dialog instanceof HTMLDialogElement) dialog.showModal();
        if (input instanceof HTMLInputElement) setTimeout(() => input.focus(), 50);
      });
      input?.addEventListener('input', (event) => {
        const query = event.target instanceof HTMLInputElement ? event.target.value.trim().toLowerCase() : '';
        let matches = 0;
        items.forEach((item) => {
          const text = item.getAttribute('data-search-text')?.toLowerCase() ?? '';
          const visible = query.length > 0 && text.includes(query);
          item.toggleAttribute('hidden', !visible);
          if (visible) matches += 1;
        });
        if (hint) hint.textContent = query ? (matches ? `找到 ${matches} 篇文章` : '没有找到相关文章') : '输入关键词，搜索全部文章。';
      });
    </script>
  </body>
</html>
